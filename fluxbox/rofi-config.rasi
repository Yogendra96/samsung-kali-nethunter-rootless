// Rofi config — samsung-kali-nethunter-rootless
// Place this in /home/kali/.config/rofi/config.rasi
// Or in /etc/rofi.conf for system-wide

configuration {
    modi:        "drun,run,window";
    show-icons:  true;
    icon-theme:  "Adwaita";
    drun-display-format: "{name}";
    location:    0;
    yoffset:     0;
    xoffset:     0;
}

// Theme — dark like Kali
@theme "gruvbox-dark"
